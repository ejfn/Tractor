{
  "name": "tractor",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "start:dev": "node scripts/inject-dev-version.js && expo start --dev-client",
    "start": "node scripts/inject-dev-version.js && expo start",
    "android": "node scripts/inject-dev-version.js && expo start --android",
    "ios": "node scripts/inject-dev-version.js && expo start --ios",
    "lint": "expo lint src/ __tests__/",
    "test": "jest",
    "test:silent": "jest --silent",
    "test:simulation": "jest __tests__/simulation/ --testPathIgnorePatterns=[]",
    "typecheck": "tsc --noEmit",
    "qualitycheck": "npm-run-all typecheck lint test:silent"
  },
  "expo": {
    "doctor": {
      "reactNativeDirectoryCheck": {
        "listUnknownPackages": false
      }
    }
  },
  "dependencies": {
    "eslint-config-expo": "~56.0.4",
    "expo": "^56.0.3",
    "expo-constants": "~56.0.14",
    "expo-dev-client": "~56.0.14",
    "expo-font": "~56.0.5",
    "expo-linking": "~56.0.11",
    "expo-localization": "~56.0.6",
    "expo-router": "~56.2.5",
    "expo-splash-screen": "~56.0.9",
    "expo-sqlite": "~56.0.4",
    "expo-status-bar": "~56.0.4",
    "expo-system-ui": "~56.0.5",
    "expo-updates": "~56.0.15",
    "i18next": "^25.2.1",
    "react": "19.2.3",
    "react-i18next": "^15.5.3",
    "react-native": "0.85.3",
    "react-native-gesture-handler": "~2.31.1",
    "react-native-reanimated": "4.3.1",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.1",
    "react-native-worklets": "0.8.3"
  },
  "devDependencies": {
    "@babel/plugin-transform-export-namespace-from": "~7.27.1",
    "@eslint/js": "^9.28.0",
    "@react-native/jest-preset": "^0.85.3",
    "@testing-library/react-native": "~13.2.0",
    "@types/jest": "~29.5.14",
    "@types/react": "~19.2.10",
    "eslint": "~9.27.0",
    "eslint-config-prettier": "~10.1.5",
    "eslint-plugin-prettier": "~5.4.0",
    "jest": "~29.7.0",
    "jest-expo": "~56.0.4",
    "npm-run-all": "~4.1.5",
    "prettier": "~3.5.3",
    "react-test-renderer": "^19.2.3",
    "tslib": "~2.8.1",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.43.0"
  },
  "overrides": {
    "react-dom": "19.2.0"
  },
  "private": true
}
