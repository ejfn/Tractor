{
  "name": "tractor",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "start:dev": "node scripts/inject-dev-version.js && expo start --dev-client",
    "start": "node scripts/inject-dev-version.js && expo start",
    "android": "node scripts/inject-dev-version.js && expo start --android",
    "ios": "node scripts/inject-dev-version.js && expo start --ios",
    "lint": "expo lint src/ __tests__/",
    "test": "jest",
    "test:silent": "jest --silent",
    "test:simulation": "jest __tests__/simulation/ --testPathIgnorePatterns=[]",
    "typecheck": "tsc --noEmit",
    "qualitycheck": "npm-run-all typecheck lint test:silent"
  },
  "expo": {
    "doctor": {
      "reactNativeDirectoryCheck": {
        "listUnknownPackages": false
      }
    }
  },
  "dependencies": {
    "eslint-config-expo": "~57.0.0",
    "expo": "^57.0.6",
    "expo-asset": "~57.0.5",
    "expo-audio": "~57.0.2",
    "expo-constants": "~57.0.5",
    "expo-dev-client": "~57.0.6",
    "expo-font": "~57.0.1",
    "expo-linking": "~57.0.3",
    "expo-localization": "~57.0.1",
    "expo-router": "~57.0.6",
    "expo-splash-screen": "~57.0.4",
    "expo-sqlite": "~57.0.1",
    "expo-status-bar": "~57.0.1",
    "expo-system-ui": "~57.0.1",
    "expo-updates": "~57.0.7",
    "i18next": "^25.10.10",
    "react": "19.2.3",
    "react-i18next": "^15.7.4",
    "react-native": "0.86.0",
    "react-native-gesture-handler": "~2.32.0",
    "react-native-reanimated": "4.5.0",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-worklets": "0.10.0"
  },
  "devDependencies": {
    "@babel/plugin-transform-export-namespace-from": "~7.27.1",
    "@eslint/js": "^9.39.5",
    "@react-native/jest-preset": "^0.86.0",
    "@testing-library/react-native": "~13.2.0",
    "@types/jest": "~29.5.14",
    "@types/react": "~19.2.17",
    "eslint": "~9.27.0",
    "eslint-config-prettier": "~10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "jest": "~29.7.0",
    "jest-expo": "~57.0.2",
    "npm-run-all": "~4.1.5",
    "prettier": "^3.9.5",
    "react-test-renderer": "^19.2.3",
    "tslib": "~2.8.1",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.64.0"
  },
  "overrides": {
    "react-dom": "19.2.0"
  },
  "private": true
}
